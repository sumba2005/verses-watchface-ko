<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared, language-independent display settings. Edited by the user in
  Garmin Connect Mobile (Connect IQ Store -> the app -> Settings), Garmin
  Express, or on-device. Read at draw time via Application.Properties.

  These live in the SHARED resources/ folder so every per-language build
  exposes the same options without duplicating them. Language itself is NOT
  a setting here: language = which face you install (lean per-language builds).
-->
<properties>
    <property id="Use24Hour"     type="boolean">false</property>
    <property id="ShowBattery"    type="boolean">true</property>
    <property id="ShowPedometer"  type="boolean">true</property>
    <property id="AccentColor"    type="number">5614079</property>   <!-- 0x55AAFF -->
    <property id="VerseInterval"  type="number">1</property>          <!-- 0=daily 1=hourly 2=fixed -->
</properties>
